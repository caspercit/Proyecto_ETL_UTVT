              Arguments="-ExecutionPolicy Bypass -Command &quot;$fecha=Get-Date -Format 'yyyyMMdd_HHmmss'; Compress-Archive -Path 'C:\Proyecto_ETL_UTVT\data\procesos\*.csv' -DestinationPath ('C:\Proyecto_ETL_UTVT\data\procesos\Procesados_' + $fecha + '.zip') -Force&quot;" />
