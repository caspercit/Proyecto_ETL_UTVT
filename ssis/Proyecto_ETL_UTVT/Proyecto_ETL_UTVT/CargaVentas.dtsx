          DTS:DTSID="{125CC0CD-EC4B-464A-B0FA-C80E0AB0AD61}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="SQL - Registrar fin del proceso"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{ABC01076-83F1-45E5-94C9-A9CE01948B35}"
              SQLTask:SqlStatementSource="UPDATE LogProceso&#xA;SET&#xA;    FechaFin = GETDATE(),&#xA;    DuracionSegundos = DATEDIFF(SECOND, FechaInicio, GETDATE()),&#xA;    TotalLeidos = (SELECT COUNT(*) FROM DimCliente)&#xA;                + (SELECT COUNT(*) FROM DimProducto)&#xA;                + (SELECT COUNT(*) FROM FactVentas),&#xA;    TotalInsertados = (SELECT COUNT(*) FROM FactVentas),&#xA;    TotalErrores = (SELECT COUNT(*) FROM LogErrores),&#xA;    Estatus = 'EXITOSO',&#xA;    Mensaje = 'Proceso ETL finalizado correctamente'&#xA;WHERE IdProceso = (&#xA;    SELECT MAX(IdProceso)&#xA;    FROM LogProceso&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\SEQ - Proceso ETL Comercializadora UTVT\SQL - Registrar inicio del proceso"
