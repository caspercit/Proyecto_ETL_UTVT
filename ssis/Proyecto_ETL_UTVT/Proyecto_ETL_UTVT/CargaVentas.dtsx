          DTS:DTSID="{D6D5D3BF-1122-4731-885E-4A3312BED575}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="SQL - Registrar inicio del proceso"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{ABC01076-83F1-45E5-94C9-A9CE01948B35}"
              SQLTask:SqlStatementSource="INSERT INTO LogProceso&#xA;(&#xA;    NombrePaquete,&#xA;    FechaInicio,&#xA;    Estatus,&#xA;    Mensaje&#xA;)&#xA;VALUES&#xA;(&#xA;    'CargaVentas.dtsx',&#xA;    GETDATE(),&#xA;    'EN PROCESO',&#xA;    'Inicio de carga ETL'&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
